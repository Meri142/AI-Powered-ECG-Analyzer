{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"gpu","dataSources":[{"sourceType":"datasetVersion","sourceId":15027433,"datasetId":9619538,"databundleVersionId":15905429}],"dockerImageVersionId":31286,"isInternetEnabled":false,"language":"python","sourceType":"script","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/idilgurbuz/syz-ders-ecg?scriptVersionId=305592004\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"code","source":"# %% [code]\n\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:13:57.682584Z\",\"iopub.execute_input\":\"2026-03-21T14:13:57.683031Z\",\"iopub.status.idle\":\"2026-03-21T14:13:57.688663Z\",\"shell.execute_reply.started\":\"2026-03-21T14:13:57.683002Z\",\"shell.execute_reply\":\"2026-03-21T14:13:57.687796Z\"}}\nimport os\nimport glob\nimport numpy as np\nimport scipy.io as sio\nimport matplotlib.pyplot as plt\nimport tensorflow as tf\nfrom tensorflow.keras import layers, models\nfrom sklearn.model_selection import train_test_split\n\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:13:57.690636Z\",\"iopub.execute_input\":\"2026-03-21T14:13:57.690878Z\",\"iopub.status.idle\":\"2026-03-21T14:13:57.709017Z\",\"shell.execute_reply.started\":\"2026-03-21T14:13:57.690854Z\",\"shell.execute_reply\":\"2026-03-21T14:13:57.708256Z\"}}\nnormal_code = ['426783006']\nrhythm_codes = ['284470004', '17338001', '164889003', '164890007', '426761007', '713422000']\nconduction_codes = ['270492004', '195042002', '54016002', '28189009', '27885002', '233917008', '164909002', '59118001']\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:13:57.710169Z\",\"iopub.execute_input\":\"2026-03-21T14:13:57.710555Z\",\"iopub.status.idle\":\"2026-03-21T14:13:57.724150Z\",\"shell.execute_reply.started\":\"2026-03-21T14:13:57.710518Z\",\"shell.execute_reply\":\"2026-03-21T14:13:57.723148Z\"}}\ndata_path = '/kaggle/input/datasets/alphanzcan/syz-large-scale-12-lead-electrocardiogram-data' # Buraya kendi veri seti ismini eklemeyi unutma\n\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:13:57.725452Z\",\"iopub.execute_input\":\"2026-03-21T14:13:57.725898Z\",\"iopub.status.idle\":\"2026-03-21T14:15:58.509934Z\",\"shell.execute_reply.started\":\"2026-03-21T14:13:57.725862Z\",\"shell.execute_reply\":\"2026-03-21T14:15:58.509102Z\"}}\nhea_files = glob.glob(os.path.join(data_path, '**/*.hea'),recursive=True)\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:15:58.512546Z\",\"iopub.execute_input\":\"2026-03-21T14:15:58.512810Z\",\"iopub.status.idle\":\"2026-03-21T14:15:58.519584Z\",\"shell.execute_reply.started\":\"2026-03-21T14:15:58.512787Z\",\"shell.execute_reply\":\"2026-03-21T14:15:58.518593Z\"}}\nall_files = []\nall_labels = []\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:15:58.520703Z\",\"iopub.execute_input\":\"2026-03-21T14:15:58.520991Z\",\"iopub.status.idle\":\"2026-03-21T14:16:32.982721Z\",\"shell.execute_reply.started\":\"2026-03-21T14:15:58.520954Z\",\"shell.execute_reply\":\"2026-03-21T14:16:32.981811Z\"}}\nfor h_file in hea_files:\n    with open(h_file, 'r') as f:\n        content = f.read()\n        if '#Dx:' in content:\n            dx_line = [line for line in content.split('\\n') if line.startswith('#Dx:')][0]\n            codes = [c.strip() for c in dx_line.replace('#Dx:', '').split(',')]\n\n            label = -1\n            if any(c in rhythm_codes for c in codes):\n                label = 1\n            elif any(c in conduction_codes for c in codes):\n                label = 2\n            elif any(c in normal_code for c in codes):\n                label = 0\n\n            if label != -1:\n                all_files.append(h_file.replace('.hea','.mat'))\n                all_labels.append(label)\n\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:16:32.984071Z\",\"iopub.execute_input\":\"2026-03-21T14:16:32.984661Z\",\"iopub.status.idle\":\"2026-03-21T14:16:32.991250Z\",\"shell.execute_reply.started\":\"2026-03-21T14:16:32.984628Z\",\"shell.execute_reply\":\"2026-03-21T14:16:32.990316Z\"}}\ndef load_12lead_data(file_list, labels, limit=5000):\n    x, y = [], []\n\n    for i in range(min(limit, len(file_list))):\n        mat = sio.loadmat(file_list[i])['val']\n        sig = mat[:12, :5000]\n        if sig.shape[1] < 5000:\n            padding = 5000 - sig.shape[1]\n            sig = np.pad(sig, ((0, 0), (0, padding)))\n        x.append(sig.T) \n        y.append(labels[i])\n    return np.array(x), np.array(y)\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:16:32.992770Z\",\"iopub.execute_input\":\"2026-03-21T14:16:32.993116Z\",\"iopub.status.idle\":\"2026-03-21T14:16:45.608541Z\",\"shell.execute_reply.started\":\"2026-03-21T14:16:32.993090Z\",\"shell.execute_reply\":\"2026-03-21T14:16:45.607537Z\"}}\nX, y = load_12lead_data(all_files, all_labels)\nX = (X - np.mean(X)) / np.std(X)\nX_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, stratify=y)\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:16:45.609756Z\",\"iopub.execute_input\":\"2026-03-21T14:16:45.610118Z\",\"iopub.status.idle\":\"2026-03-21T14:16:45.729213Z\",\"shell.execute_reply.started\":\"2026-03-21T14:16:45.610082Z\",\"shell.execute_reply\":\"2026-03-21T14:16:45.728388Z\"}}\nnames = ['Normal', 'Ritim Boz.','İletim Boz.']\ncounts = []\n\nfor i in range(3):\n    kac_tane = np.sum(y==1)\n    counts.append(kac_tane)\n\n\nplt.bar(names, counts, color=['#4CAF50', '#FF5722', '#2196F3'])\nplt.title(\"dağılım\")\nplt.show()\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:16:45.730329Z\",\"iopub.execute_input\":\"2026-03-21T14:16:45.730605Z\",\"iopub.status.idle\":\"2026-03-21T14:16:45.811839Z\",\"shell.execute_reply.started\":\"2026-03-21T14:16:45.730580Z\",\"shell.execute_reply\":\"2026-03-21T14:16:45.810988Z\"}}\nmodel = models.Sequential(\n    [\n        layers.Conv1D(32, 7, activation='relu', input_shape=(5000,12)),\n        layers.MaxPooling1D(2),\n        layers.Conv1D(64, 5, activation='relu'),\n        layers.MaxPooling1D(2),\n        layers.Conv1D(128, 3, activation='relu'),\n        layers.MaxPooling1D(2),\n        layers.Flatten(),\n        layers.Dense(64, activation='relu'),\n        layers.Dense(3, activation='softmax')\n        \n    ]\n    \n)\n\nmodel.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:16:45.812840Z\",\"iopub.execute_input\":\"2026-03-21T14:16:45.813136Z\",\"iopub.status.idle\":\"2026-03-21T14:25:26.730940Z\",\"shell.execute_reply.started\":\"2026-03-21T14:16:45.813110Z\",\"shell.execute_reply\":\"2026-03-21T14:25:26.730129Z\"}}\nhistory = model.fit(X_train, y_train, epochs=15, batch_size=32, validation_data=(X_test, y_test))\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:26.731967Z\",\"iopub.execute_input\":\"2026-03-21T14:25:26.732285Z\",\"iopub.status.idle\":\"2026-03-21T14:25:26.868457Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:26.732258Z\",\"shell.execute_reply\":\"2026-03-21T14:25:26.867631Z\"}}\nplt.plot(history.history['accuracy'], label='Eğitim')\nplt.plot(history.history['val_accuracy'], label='Test')\nplt.legend()\nplt.show()\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:26.871037Z\",\"iopub.execute_input\":\"2026-03-21T14:25:26.871572Z\",\"iopub.status.idle\":\"2026-03-21T14:25:26.875912Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:26.871545Z\",\"shell.execute_reply\":\"2026-03-21T14:25:26.875116Z\"}}\ntest_idx = np.random.randint(0, len(X_test))\ntek_ekg = X_test[test_idx].reshape(1, 5000, 12)\ngercek_etiket = y_test[test_idx]\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:26.877034Z\",\"iopub.execute_input\":\"2026-03-21T14:25:26.877375Z\",\"iopub.status.idle\":\"2026-03-21T14:25:27.069918Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:26.877338Z\",\"shell.execute_reply\":\"2026-03-21T14:25:27.069208Z\"}}\ntahmin = model.predict(tek_ekg)\ntahmin_sinif = np.argmax(tahmin)\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:27.071099Z\",\"iopub.execute_input\":\"2026-03-21T14:25:27.071460Z\",\"iopub.status.idle\":\"2026-03-21T14:25:27.077337Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:27.071394Z\",\"shell.execute_reply\":\"2026-03-21T14:25:27.076539Z\"}}\nprint(f\"Test Index: {test_idx}\")\nprint(f\"Gerçek Durum: {names[gercek_etiket]}\")\nprint(f\"Yapay Zeka Tahmini: {names[tahmin_sinif]}\")\nprint(f\"Eminlik Oranı: %{np.max(tahmin)*100:.2f}\")\n\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:27.078287Z\",\"iopub.execute_input\":\"2026-03-21T14:25:27.078793Z\",\"iopub.status.idle\":\"2026-03-21T14:25:27.419215Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:27.078766Z\",\"shell.execute_reply\":\"2026-03-21T14:25:27.418355Z\"}}\nmodel.save('ekg_modelim.keras')\nprint(\"Model kaydedildi!\")\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:27.420346Z\",\"iopub.execute_input\":\"2026-03-21T14:25:27.420687Z\",\"iopub.status.idle\":\"2026-03-21T14:25:27.748618Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:27.420659Z\",\"shell.execute_reply\":\"2026-03-21T14:25:27.747839Z\"}}\nfrom tensorflow.keras.models import load_model\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport tensorflow as tf\n\nmodel = load_model('ekg_modelim.keras')\nprint(\"Model yüklendi!\")\nprint(\"Katmanlar:\", [layer.name for layer in model.layers])\n\nsample = X_test[0:1]\nprint(\"Örnek şekli:\", sample.shape)\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:27.749647Z\",\"iopub.execute_input\":\"2026-03-21T14:25:27.749938Z\",\"iopub.status.idle\":\"2026-03-21T14:25:27.934801Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:27.749910Z\",\"shell.execute_reply\":\"2026-03-21T14:25:27.933962Z\"}}\n# Modeli bir kez çağır (örnek bir veriyle)\ndummy_input = X_train[0:1]  # veya X_test'ten bir örnek\n_ = model.predict(dummy_input)\nprint(\"Model çağrıldı, artık katmanlara erişilebilir.\")\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:27.935979Z\",\"iopub.execute_input\":\"2026-03-21T14:25:27.936576Z\",\"iopub.status.idle\":\"2026-03-21T14:25:28.731257Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:27.936547Z\",\"shell.execute_reply\":\"2026-03-21T14:25:28.730368Z\"}}\n# Modeli kaydet ve yeniden yükle\nmodel.save('son_model.keras')\nprint(\"Model kaydedildi.\")\n\nfrom tensorflow.keras.models import load_model\nmodel = load_model('son_model.keras')\nprint(\"Model yeniden yüklendi.\")\n\n# Şimdi model çağır\ndummy = X_test[0:1]\n_ = model.predict(dummy)\nprint(\"Model çağrıldı, katmanlara erişim hazır.\")\n\n# Katmanları kontrol et\nfor i, layer in enumerate(model.layers):\n    print(f\"{i}: {layer.name}\")\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:25:28.732512Z\",\"iopub.execute_input\":\"2026-03-21T14:25:28.733095Z\",\"iopub.status.idle\":\"2026-03-21T14:25:28.748473Z\",\"shell.execute_reply.started\":\"2026-03-21T14:25:28.733062Z\",\"shell.execute_reply\":\"2026-03-21T14:25:28.747459Z\"}}\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport tensorflow as tf\n\n# Son Conv1D katmanını kullan (conv1d_5)\ntarget_layer_name = \"conv1d_5\"\nprint(\"Hedef katman:\", target_layer_name)\n\n# Test örneği\nsample = X_test[0:1]\n\n# Yeni model oluştur\nintermediate_model = tf.keras.Model(\n    inputs=model.input,\n    outputs=[model.get_layer(target_layer_name).output, model.output]\n)\n\n# Grad-CAM hesapla\nwith tf.GradientTape() as tape:\n    conv_outputs, predictions = intermediate_model(sample)\n    class_idx = tf.argmax(predictions[0])\n    loss = predictions[0, class_idx]\n\ngrads = tape.gradient(loss, conv_outputs)\n\nif grads is not None:\n    pooled_grads = tf.reduce_mean(grads, axis=(0, 1))\n    conv_outputs = conv_outputs[0]\n    heatmap = tf.reduce_sum(pooled_grads * conv_outputs, axis=-1)\n    heatmap = tf.maximum(heatmap, 0) / (tf.reduce_max(heatmap) + 1e-10)\n    \n    # Görselleştir\n    plt.figure(figsize=(14, 4))\n    signal = sample[0, :, 0]  # İlk derivasyon\n    plt.plot(signal, 'b-', alpha=0.6, linewidth=1, label='EKG Sinyali')\n    \n    # Isı haritasını sinyal boyutuna getir\n    heatmap_resized = np.interp(\n        np.linspace(0, 1, len(signal)), \n        np.linspace(0, 1, len(heatmap)), \n        heatmap.numpy()\n    )\n    \n    plt.imshow(heatmap_resized.reshape(1, -1), aspect='auto', \n               cmap='hot', alpha=0.5, \n               extent=[0, len(signal), signal.min(), signal.max()])\n    \n    plt.colorbar(label='Önem Skoru')\n    plt.title(f'Grad-CAM: Modelin Odaklandığı Bölgeler (Tahmin: {class_idx.numpy()})')\n    plt.xlabel('Zaman (örnek noktası)')\n    plt.ylabel('Genlik')\n    plt.legend()\n    plt.tight_layout()\n    plt.savefig('gradcam_son.png', dpi=150)\n    plt.show()\n    print(\"✅ Başarılı! gradcam_son.png kaydedildi.\")\nelse:\n    print(\"❌ Gradyan hesaplanamadı.\")\n\n# %% [code] {\"execution\":{\"iopub.status.busy\":\"2026-03-21T14:33:24.382200Z\",\"iopub.execute_input\":\"2026-03-21T14:33:24.382966Z\",\"iopub.status.idle\":\"2026-03-21T14:33:26.037752Z\",\"shell.execute_reply.started\":\"2026-03-21T14:33:24.382931Z\",\"shell.execute_reply\":\"2026-03-21T14:33:26.036952Z\"}}\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport tensorflow as tf\nfrom tensorflow.keras.models import load_model\n\n# 1. Modeli yükle\nmodel = load_model('son_model.keras')\nprint(\"Model yüklendi.\")\n\n# 2. Otomatik olarak son Conv1D katmanını bul\ntarget_layer_name = None\nfor layer in model.layers:\n    # Katman isminde 'conv1d' geçiyorsa veya katman Conv1D tipindeyse kaydet\n    if 'conv1d' in layer.name.lower() or isinstance(layer, tf.keras.layers.Conv1D):\n        target_layer_name = layer.name\n\nif target_layer_name is None:\n    raise ValueError(\"Hata: Modelde hiçbir Conv1D katmanı bulunamadı!\")\n\nprint(f\"Hedef katman otomatik olarak bulundu: {target_layer_name}\")\n\n# 3. Yeni Ara Modeli (Functional) Oluştur\ninput_shape = X_test.shape[1:]  # Örn: (1000, 1)\nnew_input = tf.keras.Input(shape=input_shape)\n\nx = new_input\ntarget_output = None\n\nfor layer in model.layers:\n    x = layer(x)\n    if layer.name == target_layer_name:\n        target_output = x\n\nintermediate_model = tf.keras.Model(inputs=new_input, outputs=[target_output, x])\nprint(\"Ara model başarıyla oluşturuldu!\")\n\n# 4. Test örneğini hazırla\nsample = X_test[0:1].astype('float32')\nsample_tensor = tf.convert_to_tensor(sample)\n\n# 5. Grad-CAM Hesaplama\nwith tf.GradientTape() as tape:\n    tape.watch(sample_tensor)\n    conv_outputs, predictions = intermediate_model(sample_tensor)\n    \n    class_idx = tf.argmax(predictions[0])\n    loss = predictions[0, class_idx]\n\ngrads = tape.gradient(loss, conv_outputs)\n\nif grads is not None:\n    pooled_grads = tf.reduce_mean(grads, axis=(0, 1))\n    \n    conv_outputs_val = conv_outputs[0]\n    heatmap = tf.reduce_sum(pooled_grads * conv_outputs_val, axis=-1)\n    \n    heatmap = tf.maximum(heatmap, 0)\n    max_heat = tf.reduce_max(heatmap)\n    if max_heat != 0:\n        heatmap /= max_heat\n\n    # 6. Görselleştirme\n    plt.figure(figsize=(14, 4))\n    signal = sample[0, :, 0]\n    plt.plot(signal, 'b-', alpha=0.6, linewidth=1, label='Sinyal')\n    \n    heatmap_resized = np.interp(\n        np.linspace(0, 1, len(signal)), \n        np.linspace(0, 1, len(heatmap)), \n        heatmap.numpy()\n    )\n    \n    plt.imshow(heatmap_resized.reshape(1, -1), aspect='auto', \n               cmap='hot', alpha=0.4, \n               extent=[0, len(signal), signal.min(), signal.max()])\n    \n    plt.colorbar(label='Önem Skoru (Grad-CAM)')\n    plt.title(f'Sinyal Üzerinde Grad-CAM (Tahmin: {class_idx.numpy()})')\n    plt.xlabel('Zaman')\n    plt.legend()\n    plt.tight_layout()\n    plt.savefig('gradcam_fixed.png', dpi=150)\n    plt.show()\n    print(\"Başarılı! Isı haritası (heatmap) oluşturuldu.\")\nelse:\n    print(\"Gradyan hesaplanamadı.\")","metadata":{"_uuid":"2b5695b1-d9e5-4cac-acb7-accdf3583cc1","_cell_guid":"a87d54d3-7a83-437f-9727-fc8acbfe68a1","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null}]}